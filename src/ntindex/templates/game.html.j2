<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Search {{ game.name }} NeonTeam model-swap videos by source and target character.">
  <link rel="canonical" href="https://ntindex.kro.kr/game/{{ slugify(game.name) }}.html">
  <meta property="og:title" content="{{ game.name }} Model-Swap Videos - NTIndex">
  <meta property="og:description" content="Search {{ game.name }} NeonTeam model-swap videos by source and target character.">
  <meta property="og:url" content="https://ntindex.kro.kr/game/{{ slugify(game.name) }}.html">
  <meta property="og:type" content="website">
  <title>{{ game.name }} Model-Swap Videos - NTIndex</title>
  <link rel="stylesheet" href="../style.css">
</head>
<body data-game-id="{{ game.id }}">
  <main>
    <nav>
      <a class="home-link" href="../index.html" aria-label="Back to NTIndex">
        <img class="home-icon" src="../assets/home.svg" alt="">
        <span>NTIndex</span>
      </a>
    </nav>
    <header>
      <h1>{{ game.name }}</h1>
      <p>Search source and target characters.</p>
    </header>
    <section class="search">
      <label>
        Source
        <input id="sourceQuery" type="search" autocomplete="off">
      </label>
      <span class="as-text">as</span>
      <label>
        Target
        <input id="targetQuery" type="search" autocomplete="off">
      </label>
      <label>
        Sort
        <select id="sortMode">
          <option value="title-asc">Title A-Z</option>
          <option value="title-desc">Title Z-A</option>
          <option value="source-asc">Source A-Z</option>
          <option value="source-desc">Source Z-A</option>
          <option value="target-asc">Target A-Z</option>
          <option value="target-desc">Target Z-A</option>
        </select>
      </label>
    </section>
    <div id="resultCount" class="result-count"></div>
    <section id="results" class="results" aria-live="polite"></section>
    {% include "_footer.html.j2" %}
  </main>
  <script src="../search.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@tarekraafat/autocomplete.js@10.2.10/dist/autoComplete.min.js"></script>
  <script src="../app.js"></script>
</body>
</html>
