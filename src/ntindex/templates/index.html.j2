<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Search NeonTeam model-swap videos by game, source character, and target character.">
  <link rel="canonical" href="https://ntindex.kro.kr/">
  <meta property="og:title" content="NTIndex - NeonTeam Model-Swap Video Index">
  <meta property="og:description" content="Search NeonTeam model-swap videos by game, source character, and target character.">
  <meta property="og:url" content="https://ntindex.kro.kr/">
  <meta property="og:type" content="website">
  <title>NTIndex - NeonTeam Model-Swap Video Index</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <main>
    <header>
      <h1>NTIndex</h1>
      <p>NeonTeam model-swap index</p>
    </header>
    <section class="games" aria-label="Games">
      {% for game in games %}
      <a class="game-link" href="game/{{ slugify(game.name) }}.html">
        <span>{{ game.name }}</span>
        <span class="game-count">{{ game.video_count }} videos</span>
      </a>
      {% else %}
      <p>No games indexed yet.</p>
      {% endfor %}
    </section>
    {% include "_footer.html.j2" %}
  </main>
</body>
</html>
